{
  "name": "aai-brilliant-clone",
  "description": "Pyxel — an interactive, learn-by-doing web app that teaches beginners Python by writing and running real Python in the browser (Pyodide), with block coding, Parsons puzzles, test-case grading, and progress/streaks.",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "dev:local": "concurrently -k -n emulators,app -c yellow,cyan \"npm run emulators\" \"vite\"",
    "emulators": "firebase emulators:start --only auth,firestore",
    "build": "tsc -b && vite build",
    "lint": "eslint .",
    "preview": "vite preview",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:emulator": "firebase emulators:exec --only auth,firestore \"vitest run --config vitest.emulator.config.ts\"",
    "test:pyodide": "vitest run --config vitest.pyodide.config.ts",
    "validate-content": "tsx scripts/validate-content.ts",
    "gen-lesson-meta": "tsx scripts/gen-lesson-meta.ts",
    "deploy": "npm run build && firebase deploy --only hosting,firestore,functions",
    "deploy:hosting": "npm run build && firebase deploy --only hosting"
  },
  "dependencies": {
    "@codemirror/lang-python": "^6.2.1",
    "@dnd-kit/core": "^6.3.1",
    "@uiw/react-codemirror": "^4.25.10",
    "firebase": "^12.15.0",
    "motion": "^12.42.0",
    "pyodide": "^314.0.0",
    "react": "^19.2.6",
    "react-dom": "^19.2.6",
    "react-markdown": "^10.1.0",
    "react-router-dom": "^7.18.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@firebase/rules-unit-testing": "^5.0.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/node": "^24.12.3",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.1",
    "@vitest/coverage-v8": "^4.1.9",
    "concurrently": "^10.0.3",
    "eslint": "^10.3.0",
    "eslint-plugin-react-hooks": "^7.1.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "firebase-tools": "^15.22.1",
    "globals": "^17.6.0",
    "jsdom": "^29.1.1",
    "tsx": "^4.22.4",
    "typescript": "~6.0.2",
    "typescript-eslint": "^8.59.2",
    "vite": "^8.0.12",
    "vitest": "^4.1.9"
  }
}
