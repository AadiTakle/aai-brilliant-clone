rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    // The profile doc may only ever contain these fields, and the currency-ish
    // aggregates must be non-negative ints. Stops junk-field injection and type
    // confusion on the doc the Spark economy trusts for balances.
    function userShapeOk() {
      return request.resource.data.keys().hasOnly(
               ['displayName', 'email', 'totalPoints', 'currentStreak',
                'lastActiveDate', 'completedLessons', 'masteredLessons',
                'passedCheckpoints', 'activeDays', 'createdAt'])
             && request.resource.data.totalPoints is int
             && request.resource.data.totalPoints >= 0
             && request.resource.data.currentStreak is int
             && request.resource.data.currentStreak >= 0;
    }

    // A new profile must start with zeroed aggregates — a client can't sign up
    // with a pre-loaded balance.
    function aggregatesAreInitial() {
      return request.resource.data.totalPoints == 0
             && request.resource.data.currentStreak == 0
             && request.resource.data.lastActiveDate == null
             && request.resource.data.completedLessons == []
             && request.resource.data.masteredLessons == []
             && request.resource.data.passedCheckpoints == []
             && request.resource.data.activeDays == [];
    }

    // The Spark balance, streak, completion history, and mastered-lesson set are
    // SERVER-OWNED: they change only via the reward Cloud Functions (Admin SDK,
    // which bypasses these rules). A client update may edit profile fields but
    // must leave every aggregate exactly as stored, so they can't be forged.
    function aggregatesUnchanged() {
      return request.resource.data.totalPoints == resource.data.totalPoints
             && request.resource.data.currentStreak == resource.data.currentStreak
             && request.resource.data.lastActiveDate == resource.data.lastActiveDate
             && request.resource.data.completedLessons == resource.data.completedLessons
             && request.resource.data.masteredLessons == resource.data.masteredLessons
             && request.resource.data.passedCheckpoints == resource.data.passedCheckpoints
             && request.resource.data.activeDays == resource.data.activeDays;
    }

    match /users/{userId} {
      allow read: if isOwner(userId);
      allow create: if isOwner(userId) && userShapeOk() && aggregatesAreInitial();
      allow update: if isOwner(userId) && userShapeOk() && aggregatesUnchanged();

      // Custom AI-generated lessons live under the owning user. They are READ by
      // the owner but WRITTEN only by the Callable Function (Admin SDK). Blocking
      // client writes is what makes the 500-Spark charge unavoidable.
      match /aiLessons/{lessonId} {
        allow read: if isOwner(userId);
        allow write: if false;
      }
    }

    // Server-only reward ledger (written by recordStepCompletion via the Admin
    // SDK). Clients never read or write it; the balance they care about lives on
    // their user doc.
    match /rewards/{rewardId} {
      allow read, write: if false;
    }

    // Server-only one-time Mastery Challenge ledger (written by
    // commitMasteryCompletion via the Admin SDK). It guarantees the big mastery
    // Spark award fires at most once per lesson, so clients can't touch it.
    match /masteryRewards/{rewardId} {
      allow read, write: if false;
    }

    // Server-only one-time Mastery Checkpoint ledger (written by
    // commitCheckpointCompletion via the Admin SDK). It guarantees the flat
    // checkpoint Spark award fires at most once per checkpoint, so clients can't
    // touch it.
    match /checkpointRewards/{rewardId} {
      allow read, write: if false;
    }

    match /courses/{courseId} {
      allow read: if true;
      allow write: if false;
    }

    // Gameplay/resume state (current step, per-step status, last submission). This
    // is the learner's own non-currency progress; points here are display-only —
    // the authoritative balance is server-awarded on the user doc.
    match /progress/{progressId} {
      allow read, write: if isSignedIn()
        && progressId.matches('^' + request.auth.uid + '_.*');
    }
  }
}
