VITE_FIREBASE_API_KEY=your-api-key
VITE_FIREBASE_AUTH_DOMAIN=your-project.firebaseapp.com
VITE_FIREBASE_PROJECT_ID=your-project-id
VITE_FIREBASE_STORAGE_BUCKET=your-project.appspot.com
VITE_FIREBASE_MESSAGING_SENDER_ID=your-sender-id
VITE_FIREBASE_APP_ID=your-app-id

# Use Firebase Emulators for fully offline local dev (requires Java).
VITE_USE_FIREBASE_EMULATORS=false

# --- AI custom lessons ---
# Which generator the client uses: "stub" (default, offline, no key needed) or
# "callable" (routes through the deployed Firebase Function that holds the OpenAI key).
VITE_AI_BACKEND=stub
# reCAPTCHA v3 site key for App Check (optional locally; needed to enforce the
# callable in production). The OpenAI API key is NOT set here — it is a Cloud
# Functions secret: `firebase functions:secrets:set OPENAI_API_KEY`.
VITE_FIREBASE_APPCHECK_KEY=
